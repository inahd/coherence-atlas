#!/usr/bin/env python3

import os,sys,subprocess,json

def run(cmd):
    subprocess.run(cmd,shell=True)

def seed():
    name=input("Seed name: ").strip().replace(" ","_")
    path=f"seeds/{name}.md"
    os.makedirs("seeds",exist_ok=True)
    open(path,"w").write(f"# {name}\n\nidea:\n\nrelations:\n")
    print("Seed created:",path)

def build():
    run("python tools/build_graph.py")

def map():
    run("python tools/render_constellation.py")
    print("Open with: firefox visual/atlas_constellation.html")

def thali():

    print("\n=== ATLAS THALI ===\n")

    print("Seeds:")
    if os.path.exists("seeds"):
        print(len(os.listdir("seeds")),"seed files")

    if os.path.exists("atlas_graph/graph.json"):
        data=json.load(open("atlas_graph/graph.json"))
        print("Nodes:",len(data["nodes"]))
        print("Edges:",len(data["edges"]))

    if os.path.exists("visual/atlas_constellation.html"):
        print("Constellation present")

    print("\nArtifacts:")
    print("atlas_graph/graph.json")
    print("visual/atlas_constellation.html")

def offer():
    run("python tools/build_graph.py")
    run("python tools/render_constellation.py")
    run("git add .")
    run("git commit -m 'atlas: thali offering cycle'")
    run("git push")

cmd=sys.argv[1] if len(sys.argv)>1 else ""

if cmd=="seed":
    seed()
elif cmd=="build":
    build()
elif cmd=="map":
    map()
elif cmd=="thali":
    thali()
elif cmd=="offer":
    offer()
else:
    print("""
Atlas commands:

atlas seed   — plant research seed
atlas build  — build knowledge graph
atlas map    — render constellation
atlas thali  — show offering plate
atlas offer  — full cycle commit
""")
