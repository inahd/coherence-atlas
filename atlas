#!/usr/bin/env python3
import sys
import subprocess

def run(cmd):
    subprocess.run(cmd, shell=True)

if len(sys.argv) < 2:
    print("""
Atlas AI CLI

Commands:

chat        → AI router
agent       → dev agent
memory      → rebuild vector memory
index       → rebuild project index
models      → list ollama models
dashboard   → start dashboard
shell       → dev AI shell
analyze     → analyze project code
patch       → AI patch a file
watch       → start project watcher
research    → ingest research corpus
""")
    sys.exit()

cmd = sys.argv[1]

if cmd == "chat":
    run("python /opt/atlas/scripts/ai_router.py")

elif cmd == "agent":
    run("python /opt/atlas/scripts/dev_agent.py")

elif cmd == "memory":
    run("python /opt/atlas/scripts/vector_memory.py")

elif cmd == "index":
    run("python /opt/atlas/scripts/index_project.py")

elif cmd == "models":
    run("ollama list")

elif cmd == "dashboard":
    run("python /opt/atlas/scripts/control_panel.py")

elif cmd == "shell":
    run("python /opt/atlas/scripts/dev_ai_shell.py")

elif cmd == "analyze":
    run("python /opt/atlas/scripts/code_analyzer.py")

elif cmd == "patch":
    if len(sys.argv) < 3:
        print("Usage: atlas patch <file>")
    else:
        run(f"python /opt/atlas/scripts/ai_patch.py {sys.argv[2]}")

elif cmd == "watch":
    run("python /opt/atlas/scripts/atlas_watcher.py")

elif cmd == "research":
    run("python /opt/atlas/scripts/research_ingest.py")

else:
    print("Unknown command")
